{
  "name": "omnicraft-desktop-electron",
  "productName": "OmniCraft",
  "version": "0.3.0",
  "description": "Shell desktop do OmniCraft (edição Electron) — um wrapper nativo leve sobre a interface web servida pelo servidor.",
  "private": true,
  "main": "src/main.js",
  "homepage": "https://omnicraft.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/omnicraft-ai/omnicraft.git"
  },
  "author": {
    "name": "Databricks, Inc.",
    "email": "support@omnicraft.ai"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "test": "node --test",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:mac:release": "electron-builder --mac -c.mac.notarize=true",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^42.3.2",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "ai.omnicraft.desktop",
    "productName": "OmniCraft",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "omnicraft-ai",
        "repo": "omnicraft"
      }
    ],
    "afterPack": "build/afterPack.js",
    "files": [
      "src/**/*",
      "setup/**/*",
      "find/**/*",
      "icons/**/*"
    ],
    "extraResources": [
      {
        "from": "../platform-assets",
        "to": "platform-assets",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "icons/icon.icns",
      "identity": "Databricks, Inc. (8RMX4WU6F8)",
      "provisioningProfile": "signing/omnicraft.provisionprofile",
      "hardenedRuntime": true,
      "entitlements": "signing/entitlements.mac.plist",
      "entitlementsInherit": "signing/entitlements.mac.inherit.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "O OmniCraft usa o microfone para ditado por voz no compositor de mensagens.",
        "CFBundleIconName": "AppIcon"
      },
      "gatekeeperAssess": false,
      "notarize": false,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "background": "dmg/background.tiff",
      "window": {
        "width": 640,
        "height": 465
      },
      "iconSize": 96,
      "contents": [
        {
          "x": 170,
          "y": 100
        },
        {
          "x": 470,
          "y": 100,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "icon": "icons/icon.png",
      "category": "Development",
      "maintainer": "Databricks, Inc. <support@omnicraft.ai>",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "win": {
      "icon": "icons/icon.ico",
      "artifactName": "OmniCraft-Setup-${version}.${ext}",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OmniCraft"
    }
  },
  "dependencies": {
    "js-yaml": "^4.2.0"
  }
}
